# ========================================
# データベース設定
# ========================================
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=kasa_blog_db
MYSQL_USER=kasa_user
MYSQL_PASSWORD=kasa_password

# ========================================
# バックエンド（FastAPI）設定
# ========================================
# SQLAlchemy用のデータベースURL
DATABASE_URL=mysql+pymysql://root:${MYSQL_ROOT_PASSWORD}@mysql:3306/${MYSQL_DATABASE}

# JWT認証設定
JWT_SECRET_KEY=your-strong-secret-key
# CORSで許可するオリジン（カンマ区切りで複数指定可）
CORS_ORIGINS=http://localhost:3000
# HTTPSを使う本番環境では true に変更
SECURE_COOKIES=false

# ========================================
# フロントエンド（Next.js）設定
# ========================================
# ブラウザからAPIにアクセスするURL（クライアントコンポーネント用・ビルド時に埋め込まれる）
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# サーバーサイドからAPIにアクセスするURL（コンテナ内部通信・サーバーコンポーネント用）
# 本番環境は docker-compose.yml の next-prod environment で上書きされる
API_INTERNAL_URL=http://kasa-blog-api:8000/api

# ========================================
# Sakura Cloud Object Storage（S3互換）設定
# ========================================
S3_ENDPOINT_URL=https://s3.isk01.sakurastorage.jp
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key
S3_BUCKET_NAME=your-bucket-name

# ========================================
# Docker Hub 設定
# ========================================
DOCKER_HUB_USERNAME=your-username

# ========================================
# ポート設定
# ========================================
FASTAPI_PORT=8000
MYSQL_PORT=3306
NEXT_DEV_PORT=3000
NEXT_PROD_PORT=3001
NGINX_PORT=80
